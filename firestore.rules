rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Today's only admin action that writes via a client (the submission
    // visibility toggle) uses this. /api/sync still writes via the Admin
    // SDK, which bypasses these rules entirely.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Toss = 30 minutes before match start. matchTimestamp is denormalized
    // onto each userSquads doc at save time so this needs no extra read.
    function hasTossPassed(matchTimestamp) {
      return request.time > timestamp.value(matchTimestamp) - duration.value(30, 'm');
    }

    // The submission-visibility toggle is a single settings/visibility doc
    // carrying { hideUntilToss, date }. It only ever applies to the one day
    // it names, so a stale "on" from a past day is automatically inert —
    // no cron/reset job needed.
    function isVisibilityHiddenForDay(matchDay) {
      let path = /databases/$(database)/documents/settings/visibility;
      return exists(path) && get(path).data.hideUntilToss == true && get(path).data.date == matchDay;
    }

    // Cross-checks a write's denormalized matchTimestamp/matchDay against
    // the real match doc (one extra read) so a client can't spoof toss time
    // or the visibility-toggle day fields. matchDay is verified as a
    // literal prefix of matchTimestamp via matches() (a full-string regex
    // match) since rules has no substring/slice operator.
    function matchesSourceOfTruth(data) {
      let m = get(/databases/$(database)/documents/matches/$(data.matchId)).data;
      return data.matchTimestamp == m.date &&
        data.matchTimestamp.matches(data.matchDay + 'T.*');
    }

    // Exactly 3 players, MVP among them, doc ID consistent with {userId}_{matchId}
    // — mirrors src/lib/draftRules.ts's shape rules (dual-franchise check stays
    // client-only; it needs player-team data rules doesn't have).
    function isValidSquadShape(squadId, data) {
      return data.players is list &&
        data.players.size() == 3 &&
        data.playerNames is list &&
        data.playerNames.size() == 3 &&
        data.mvpId in data.players &&
        squadId == data.userId + '_' + data.matchId;
    }

    match /userSquads/{squadId} {
      allow read: if isSignedIn() && (
        resource == null ||
        isOwner(resource.data.userId) ||
        hasTossPassed(resource.data.matchTimestamp) ||
        !isVisibilityHiddenForDay(resource.data.matchDay)
      );
      allow create: if isOwner(request.resource.data.userId) &&
        isValidSquadShape(squadId, request.resource.data) &&
        matchesSourceOfTruth(request.resource.data) &&
        !hasTossPassed(request.resource.data.matchTimestamp);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId) &&
        isValidSquadShape(squadId, request.resource.data) &&
        matchesSourceOfTruth(request.resource.data) &&
        !hasTossPassed(resource.data.matchTimestamp) &&
        !hasTossPassed(request.resource.data.matchTimestamp);
      allow delete: if isOwner(resource.data.userId) &&
        !hasTossPassed(resource.data.matchTimestamp);
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if false; // Admin only via API sync with service account if available, or just blocked for clients
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if false;
    }

    // Written only by the Admin SDK (finalize-match, admin/users routes),
    // which bypasses these rules entirely — so `write: if false` here is
    // just confirming there is no client write path, not doing enforcement.
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
